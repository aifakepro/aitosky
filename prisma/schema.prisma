generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ТАБЛИЦЫ ДЛЯ AUTH.JS (NEXTAUTH) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Auth поля (не трогаем)
  role        String    @default("user")
  balance     Float     @default(0)
  lastLoginAt DateTime?

  // ← НОВЫЕ поля профиля
  firstname String?
  lastname  String?
  contactno String?
  country   String?
  city      String?

  // Связи
  accounts           Account[]
  sessions           Session[]
  assets             UserAsset[]
  jobs               UserJob[] // ← НОВАЯ связь
  dashboardBarChart  DashboardBarChart[]
  dashboardAreaChart DashboardAreaChart[]
  dashboardPieChart  DashboardPieChart[]
  boards             Board[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ← НОВАЯ таблица для опыта работы
model UserJob {
  id         String @id @default(cuid())
  userId     String
  jobcountry String
  jobcity    String
  jobtitle   String
  employer   String
  startdate  String
  enddate    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- ТВОЯ ЛОГИКА АКТИВОВ ---

// Актив (Вещь), которой торгуют (напр: "Золото", "BTC")
model Asset {
  id           String @id @default(cuid())
  name         String
  symbol       String @unique // Код, напр. GOLD, BTC
  currentPrice Float

  priceHistory PriceHistory[]
  userAssets   UserAsset[]
}

// История цен для графиков
model PriceHistory {
  id        String   @id @default(cuid())
  assetId   String
  price     Float
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// Портфель пользователя (что он купил)
model UserAsset {
  id       String @id @default(cuid())
  userId   String
  assetId  String
  quantity Float // Сколько единиц купил

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DashboardBarChart {
  id      String @id @default(cuid())
  date    String
  desktop Int
  mobile  Int
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DashboardAreaChart {
  id        String   @id @default(cuid())
  month     String
  desktop   Int
  mobile    Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt // Авто-обновление времени изменения

  @@unique([userId, month])
}

model DashboardPieChart {
  id       String @id @default(cuid())
  browser  String
  visitors Int
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, browser])
}

model Board {
  id     String @id @default(cuid())
  title  String
  userId String

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns Column[]

  createdAt DateTime @default(now())
}

model Column {
  id      String @id @default(cuid())
  title   String
  order   Int
  boardId String

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int
  columnId    String

  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
